REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
MEDIA_AI_QUEUE_KEY=media-ai:jobs
# 分队列前缀（API 与 Worker 需一致）：{prefix}:cpu / :tts / :latentsync / :flashhead
MEDIA_AI_QUEUE_PREFIX=media-ai:jobs
# 留空则监听全部 4 个队列；专用 Worker 示例：media-ai:jobs:latentsync
# WORKER_QUEUE_KEYS=media-ai:jobs:latentsync

STORAGE_LOCAL_PATH=storage
API_BASE_URL=http://localhost:3000/api
MEDIA_WORKER_SECRET=change-me-media-worker-secret

WORKER_POLL_TIMEOUT=5

# GPU 任务串行排队（Redis 锁）：同一时刻只跑一个 GPU 任务，显存不足时等待
# GPU_LOCK_KEY=media-ai:gpu:lock
# GPU_SIGNAL_KEY=media-ai:gpu:signal
# GPU_WAIT_POLL_SECONDS=2
# GPU_FLASHHEAD_REQUIRED_MB=8000
# GPU_INDEXTTS2_REQUIRED_MB=6000
# GPU_LATENTSYNC_REQUIRED_MB=14000

# Whisper 字幕识别 / live_slice 回退 ASR
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
HF_ENDPOINT=https://hf-mirror.com
# WHISPER_MODEL_PATH=
# WHISPER_LOCAL_ONLY=false

# ASR：auto=FunASR 优先，失败回退 Whisper；也可设为 funasr / whisper
ASR_ENGINE=auto
FUNASR_MODEL=paraformer-zh
FUNASR_VAD_MODEL=fsmn-vad
FUNASR_PUNC_MODEL=ct-punc
FUNASR_DEVICE=cpu
FUNASR_BATCH_SIZE_S=300

# yt-dlp 平台视频下载（小红书/视频号/B站/TikTok 等；抖音/快手已内置解析器）
# 仅在 yt-dlp 解析失败且平台需要登录时，可选配置 Cookie：
# YTDLP_COOKIES_FILE=D:/workbench/ViralEngine-api/media-worker/cookies/cookies.txt

# LLM 高光识别（OpenAI 兼容；推荐通义千问，详见 docs/dashscope-llm-api.md）
# 通义（推荐）：
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_MODEL=qwen-plus
LLM_TIMEOUT=120
# 省钱可改为 qwen-turbo；验证：python scripts/verify_llm.py
# DeepSeek 示例：
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=deepseek-chat

# IndexTTS2 语音合成（本机已下载的仓库路径）
# 推荐配置 INDEXTTS2_PYTHON，任务到达时子进程按需加载，worker 主进程不占 GPU
# INDEXTTS2_REPO_PATH=D:/workbench/talk/IndexTTS2
# INDEXTTS2_MODEL_DIR=D:/workbench/talk/IndexTTS2/checkpoints
# INDEXTTS2_DEVICE=cuda:0
# INDEXTTS2_USE_FP16=true
# INDEXTTS2_USE_CUDA_KERNEL=true
# INDEXTTS2_PYTHON=D:/workbench/talk/IndexTTS2/.venv/Scripts/python.exe
# Docker GPU: INDEXTTS2_PYTHON=/opt/venvs/indextts2/bin/python

# SoulX FlashHead Pro 口播数字人
# FLASHHEAD_REPO_PATH=D:/workbench/FlashHeadLite
# FLASHHEAD_CKPT_DIR=D:/workbench/FlashHeadLite/models/SoulX-FlashHead-1_3B
# FLASHHEAD_WAV2VEC_DIR=D:/workbench/FlashHeadLite/models/wav2vec2-base-960h
# FLASHHEAD_PYTHON=D:/workbench/FlashHeadLite/.venv/Scripts/python.exe
# Docker GPU: FLASHHEAD_PYTHON=/opt/venvs/flashhead/bin/python

# LatentSync 视频对口型
# LATENTSYNC_REPO_PATH=D:/workbench/LatentSync
# LATENTSYNC_CKPT_PATH=D:/workbench/LatentSync/checkpoints/latentsync_unet.pt
# LATENTSYNC_UNET_CONFIG=D:/workbench/LatentSync/configs/unet/stage2_512.yaml
# LATENTSYNC_PYTHON=D:/workbench/LatentSync/venv/Scripts/python.exe
# 常驻推理服务（推荐）：配置后 Worker 走 HTTP，模型只加载一次
# LATENTSYNC_SERVER_URL=http://127.0.0.1:8102
# LATENTSYNC_SERVER_PORT=8102
# LatentSync venv 需安装服务依赖：pip install fastapi uvicorn httpx pydantic-settings
# Docker GPU: LATENTSYNC_PYTHON=/opt/venvs/latentsync/bin/python
