REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
MEDIA_AI_QUEUE_KEY=media-ai:jobs

STORAGE_LOCAL_PATH=storage
API_BASE_URL=http://localhost:3000/api
MEDIA_WORKER_SECRET=change-me-media-worker-secret

WORKER_POLL_TIMEOUT=5

# Whisper 字幕识别（首次运行需下载模型，建议先执行 scripts/download_whisper_model.py）
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# 国内网络无法访问 huggingface.co 时启用镜像
HF_ENDPOINT=https://hf-mirror.com
# 已下载模型的本地目录（设置后优先于 WHISPER_MODEL）
# WHISPER_MODEL_PATH=
# 仅使用本地缓存，禁止联网（需已下载模型）
# WHISPER_LOCAL_ONLY=false
