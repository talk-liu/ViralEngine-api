# App
NODE_ENV=development
PORT=3000

# CORS（逗号分隔；生产环境请配置实际前端域名。开发环境自动放行 localhost / wails.localhost）
# CORS_ORIGINS=http://localhost:5173,http://wails.localhost:34115

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=viralengine
DB_PASSWORD=viralengine
DB_DATABASE=viralengine
DB_SYNCHRONIZE=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d

# Throttle (ttl=毫秒, limit=窗口内最大请求数)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# SMS / Captcha
SMS_CODE_TTL=300
SMS_COOLDOWN_TTL=60
CAPTCHA_TTL=300

# Token 加密密钥（生产环境请使用独立随机字符串；未设置时回退 JWT_SECRET）
# ENCRYPTION_KEY=

# 抖音开放平台 OAuth（client_secret 仅服务端保存）
DOUYIN_CLIENT_KEY=awvyiwu8e6s838k1
DOUYIN_CLIENT_SECRET=7c808ac9a0ec260b6bee5a742dd0ab6b
DOUYIN_REDIRECT_URI=http://localhost:3000/api/oauth/douyin/callback

# 快手开放平台 OAuth
KUAISHOU_APP_ID=
KUAISHOU_APP_SECRET=
KUAISHOU_REDIRECT_URI=http://localhost:3000/api/oauth/kuaishou/callback
