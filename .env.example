# App
NODE_ENV=development
PORT=3000

# 桌面客户端版本发布（GET /api/app/release，无需登录）
APP_LATEST_VERSION=1.0.0
APP_DOWNLOAD_URL=
# APP_RELEASE_NOTES=
# APP_FORCE_UPDATE=false

# 本地 HTTPS（OAuth 回调，API 默认 3443，避免与桌面端 58473 冲突）
HTTPS_ENABLED=true
# 本机仅访问用 127.0.0.1；局域网访问用 0.0.0.0
HTTPS_HOST=127.0.0.1
HTTPS_PORT=3443
# SSL_KEY_PATH=certs/dev-key.pem
# SSL_CERT_PATH=certs/dev-cert.pem
# 留空则自动生成: https://{HTTPS_HOST}:{HTTPS_PORT}/api/oauth/{platform}/callback
# 局域网 OAuth 示例（HTTPS_HOST=0.0.0.0 时必填，填本机局域网 IP）:
# OAUTH_CALLBACK_BASE_URL=https://192.168.6.57:3443
# 生成含局域网 IP 的证书: DEV_CERT_IP=192.168.6.57 DEV_CERT_FORCE=true npm run certs:generate

# CORS（逗号分隔；生产环境请配置实际前端域名。开发环境自动放行 localhost / wails.localhost）
# CORS_ORIGINS=http://localhost:5173,http://wails.localhost:34115

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=viralengine
DB_PASSWORD=viralengine
DB_DATABASE=viralengine
DB_SYNCHRONIZE=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d

# 管理员：将对应用户的 is_admin 设为 1，例如：
# UPDATE users SET is_admin = 1 WHERE phone = '13800138000';

# Throttle (ttl=毫秒, limit=窗口内最大请求数)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# SMS / Captcha
SMS_CODE_TTL=300
SMS_COOLDOWN_TTL=60
CAPTCHA_TTL=300

# 腾讯云短信 SDK 3.0（生产环境必填；开发环境未配置时仅日志输出 debugCode）
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_REGION=

# Token 加密密钥（生产环境请使用独立随机字符串；未设置时回退 JWT_SECRET）
# ENCRYPTION_KEY=

# 抖音开放平台 OAuth（client_secret 仅服务端保存）
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
# 留空则使用 HTTPS 自动生成回调地址
# DOUYIN_REDIRECT_URI=https://127.0.0.1:3443/api/oauth/douyin/callback

# 快手开放平台 OAuth
KUAISHOU_APP_ID=
KUAISHOU_APP_SECRET=
# KUAISHOU_REDIRECT_URI=https://127.0.0.1:3443/api/oauth/kuaishou/callback

# 发布草稿素材（本地存储，生产可换 S3/MinIO）
STORAGE_LOCAL_PATH=storage
# 留空则签名 URL 使用 http://localhost:PORT/api/publish-draft-assets/content
# STORAGE_PUBLIC_BASE_URL=http://localhost:3000/api
STORAGE_SIGNED_URL_TTL=3600
# STORAGE_SIGNED_URL_SECRET=

# Media AI Worker（Python 媒体处理服务，详见 media-worker/.env.example）
MEDIA_AI_QUEUE_KEY=media-ai:jobs
# 任务分队列前缀：latentsync/tts/flashhead 走 GPU 专用队列，其余走 :cpu
MEDIA_AI_QUEUE_PREFIX=media-ai:jobs
MEDIA_WORKER_SECRET=change-me-media-worker-secret
# 任务产出（字幕/水印视频/直播切片）在 completed 后的保留时长（小时），超时自动删文件
MEDIA_JOB_OUTPUT_RETENTION_HOURS=12

# 通义千问 LLM（前端 generate/video-details + 直播切片 Worker，详见 docs/dashscope-llm-api.md）
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_MODEL=qwen-plus
LLM_TIMEOUT=120

# Docker GPU Worker 模型挂载路径（见 docs/docker-media-worker-gpu.md）
# INDEXTTS2_HOST_PATH=D:/workbench/talk/IndexTTS2
# FLASHHEAD_HOST_PATH=D:/workbench/FlashHeadLite
# LATENTSYNC_HOST_PATH=D:/workbench/LatentSync

# 草稿限制
DRAFT_MAX_COUNT_PER_USER=100
# DRAFT_VIDEO_MAX_BYTES=4294967296
# DRAFT_COVER_MAX_BYTES=10485760

# 素材库（永久保留，仅用户主动删除；与草稿共用 STORAGE_* 本地存储配置）
MATERIAL_MAX_COUNT_PER_USER=500
# MATERIAL_IMAGE_MAX_BYTES=10485760
# MATERIAL_AUDIO_MAX_BYTES=104857600
# MATERIAL_VIDEO_MAX_BYTES=4294967296
