# App
NODE_ENV=development
PORT=3000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=viralengine
DB_PASSWORD=viralengine
DB_DATABASE=viralengine
DB_SYNCHRONIZE=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d

# Throttle (ttl=毫秒, limit=窗口内最大请求数)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# SMS / Captcha
SMS_CODE_TTL=300
SMS_COOLDOWN_TTL=60
CAPTCHA_TTL=300
