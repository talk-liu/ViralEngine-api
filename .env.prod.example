# ========== 镜像地址（服务器必填）==========
# 阿里云 ACR 个人版 · 上海 · 命名空间 viral-engine-api
# 本机 push 后把 tag 换成脚本输出的 commit 或版本号
API_IMAGE=crpi-mm6tfxx66owmuulg.cn-shanghai.personal.cr.aliyuncs.com/viral-engine-api/viralengine-api:latest
# 仅启动 Node API 时可省略；compose 用 docker-compose.prod.api.yml
# MEDIA_WORKER_IMAGE=crpi-mm6tfxx66owmuulg.cn-shanghai.personal.cr.aliyuncs.com/viral-engine-api/viralengine-media-worker:latest
# GPU 场景:
# MEDIA_WORKER_GPU_IMAGE=crpi-mm6tfxx66owmuulg.cn-shanghai.personal.cr.aliyuncs.com/viral-engine-api/viralengine-media-worker-gpu:latest

# ========== 应用 ==========
NODE_ENV=production
# 容器内应用固定 3000（compose 会强制 PORT=3000，勿改成 3003）
PORT=3000
# 宿主机对外端口，避免与 3000 冲突时改为 3003
API_HOST_PORT=3003
HTTPS_ENABLED=false
SWAGGER_ENABLED=false
# CORS_ORIGINS=https://your-frontend.example.com
# OAUTH_CALLBACK_BASE_URL=https://api.example.com
# STORAGE_PUBLIC_BASE_URL=https://api.example.com/api

# ========== MySQL（容器内 api 连 mysql 服务名）==========
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=viralengine
DB_PASSWORD=change-me-strong-password
DB_DATABASE=viralengine
DB_SYNCHRONIZE=false
DB_ROOT_PASSWORD=change-me-root-password

# ========== Redis ==========
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========== 密钥（全部换成随机长字符串）==========
JWT_SECRET=change-me-jwt-secret
JWT_EXPIRES_IN=7d
MEDIA_WORKER_SECRET=change-me-media-worker-secret
# ENCRYPTION_KEY=change-me-encryption-key

# ========== OAuth / LLM / 存储（按需填写）==========
# DOUYIN_CLIENT_KEY=
# DOUYIN_CLIENT_SECRET=
# KUAISHOU_APP_ID=
# KUAISHOU_APP_SECRET=
# LLM_API_KEY=
STORAGE_LOCAL_PATH=storage

# ========== GPU 模型挂载路径（仅 GPU 部署需要，填服务器上的绝对路径）==========
# INDEXTTS2_HOST_PATH=/data/models/IndexTTS2
# FLASHHEAD_HOST_PATH=/data/models/FlashHeadLite
# LATENTSYNC_HOST_PATH=/data/models/LatentSync
